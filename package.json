{
  "name": "atproto-notifs",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @atmo/notifs-relay dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "generate": "pnpm --filter @atmo/notifs-lexicons generate",
    "db:migrate": "pnpm --filter @atmo/notifs-relay db:migrate",
    "typecheck": "tsc -b",
    "icons": "node scripts/generate-icons.mjs"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "png-to-ico": "^2.1.8",
    "typescript": "^5.8.3"
  }
}
