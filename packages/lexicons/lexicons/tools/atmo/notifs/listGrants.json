{
  "lexicon": 1,
  "id": "tools.atmo.notifs.listGrants",
  "defs": {
    "main": {
      "type": "query",
      "description": "List the senders the authenticated user has granted notification permission to. User-authenticated.",
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["grants"],
          "properties": {
            "grants": {
              "type": "array",
              "items": { "type": "ref", "ref": "#grantView" }
            }
          }
        }
      }
    },
    "grantView": {
      "type": "object",
      "required": ["sender", "title", "grantedAt", "muted"],
      "properties": {
        "sender": { "type": "string", "format": "did" },
        "title": {
          "type": "string",
          "description": "Display name for the sender (user-supplied at request time, falling back to Bluesky info or the DID)."
        },
        "description": { "type": "string" },
        "iconUrl": { "type": "string" },
        "senderHandle": {
          "type": "string",
          "description": "Best-effort Bluesky handle for the sender DID, if it has a profile."
        },
        "senderBskyDisplayName": { "type": "string" },
        "senderBskyAvatar": { "type": "string" },
        "grantedAt": { "type": "string", "format": "datetime" },
        "muted": { "type": "boolean" }
      }
    }
  }
}
