{
  "lexicon": 1,
  "id": "tools.atmo.notifs.unlinkChannel",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Unlink a delivery channel (by device id) from the authenticated user. User-authenticated.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["deviceId"],
          "properties": {
            "deviceId": { "type": "string" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["unlinked"],
          "properties": {
            "unlinked": { "type": "boolean" }
          }
        }
      }
    }
  }
}
