{
  "lexicon": 1,
  "id": "tools.atmo.notifs.grant",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Grant a sender permission to notify the authenticated user. User-authenticated.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["sender"],
          "properties": {
            "sender": { "type": "string", "format": "did" },
            "requestId": {
              "type": "string",
              "description": "If provided, the matching pending request is consumed."
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["granted"],
          "properties": {
            "granted": { "type": "boolean" }
          }
        }
      }
    }
  }
}
