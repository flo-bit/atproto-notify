{
  "lexicon": 1,
  "id": "tools.atmo.notifs.revoke",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Revoke a sender's permission to notify the authenticated user. User-authenticated.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["sender"],
          "properties": {
            "sender": { "type": "string", "format": "did" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["revoked"],
          "properties": {
            "revoked": { "type": "boolean" }
          }
        }
      }
    }
  }
}
