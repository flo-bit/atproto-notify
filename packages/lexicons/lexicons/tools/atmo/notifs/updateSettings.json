{
  "lexicon": 1,
  "id": "tools.atmo.notifs.updateSettings",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Partially update the authenticated user's notification settings. Only fields present in the input are changed. User-authenticated.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "notifyPendingViaTelegram": { "type": "boolean" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["notifyPendingViaTelegram"],
          "properties": {
            "notifyPendingViaTelegram": { "type": "boolean" }
          }
        }
      }
    }
  }
}
