{
  "lexicon": 1,
  "id": "pub.atmo.notify.denyPending",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Delete a pending permission request without granting it. Does not blocklist the sender. User-authenticated.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["requestId"],
          "properties": {
            "requestId": { "type": "string" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["denied"],
          "properties": {
            "denied": { "type": "boolean" }
          }
        }
      }
    }
  }
}
