{
  "lexicon": 1,
  "id": "pub.atmo.notify.updateSettings",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Partially update the authenticated user's notification settings. Only fields present in the input are changed. User-authenticated.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "pendingRoute": {
              "type": "string",
              "description": "Where permission-request alerts go: a '+'-joined token set or 'off'."
            },
            "autoAllow": {
              "type": "string",
              "enum": ["all", "trusted", "none"],
              "description": "Policy for incoming permission requests."
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["pendingRoute"],
          "properties": {
            "pendingRoute": { "type": "string" }
          }
        }
      }
    }
  }
}
